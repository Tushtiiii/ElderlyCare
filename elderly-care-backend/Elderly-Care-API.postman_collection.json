          "name": "Get Vitals (Guardian)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{guardian_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/vitals?elderId={{elder_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "vitals"],
              "query": [
                {
                  "key": "elderId",
                  "value": "{{elder_id}}"
                }
              ]
            }
          }
        }
      ]
