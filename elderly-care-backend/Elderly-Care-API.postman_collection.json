  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints",
      "item": [
        {
          "name": "Register - Elder",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"elder_token\", jsonData.token);",
                  "    pm.environment.set(\"elder_id\", jsonData.userId);",
                  "    console.log('Elder registered:', jsonData.email);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"name\\\": \\\"John Anderson\\\",\\n  \\\"email\\\": \\\"elder.demo@example.com\\\",\\n  \\\"password\\\": \\\"DemoPass@123\\\",\\n  \\\"phone\\\": \\\"+1234567890\\\",\\n  \\\"role\\\": \\\"ELDER\\\",\\n  \\\"dateOfBirth\\\": \\\"1950-05-15\\\"\\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
