    {
      "name": "Users",
      "description": "User profile endpoints",
      "item": [
        {
          "name": "Get Current User (Elder)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{elder_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/me",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "me"]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{guardian_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/{{elder_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{elder_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Relationships",
      "description": "Relationship management endpoints",
      "item": [
        {
          "name": "Request Relationship (Guardian → Elder)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{guardian_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"targetUserEmail\\\": \\\"elder.demo@example.com\\\"\\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/relationships/request",
              "host": ["{{base_url}}"],
              "path": ["api", "relationships", "request"]
            }
          }
        },
        {
          "name": "Get Pending Relationships",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{elder_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/relationships/pending",
              "host": ["{{base_url}}"],
              "path": ["api", "relationships", "pending"]
            }
          }
        },
        {
          "name": "Approve Relationship",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{elder_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/relationships/{relationshipId}/approve",
              "host": ["{{base_url}}"],
              "path": ["api", "relationships", "{relationshipId}", "approve"]
            }
          }
        }
      ]
