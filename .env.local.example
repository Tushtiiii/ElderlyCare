# Google OAuth Configuration - TEMPLATE
# Copy this file to .env.local and fill in your actual credentials
# Get these from: https://console.cloud.google.com/

# For Expo App (Web + Android)
# Use Android OAuth Client ID (supports deep links)
# Redirect URI: com.anonymous.Elderlycare://oauth/callback
# Package: com.anonymous.Elderlycare
# SHA-1 Fingerprint: AA:C4:8D:F4:6D:02:B0:D1:3D:4D:3D:11:5D:99:F2:66:A4:E9:39:9A
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=YOUR_ANDROID_CLIENT_ID_HERE

# Optional: Web OAuth credentials (for separate React web app)
# OAuth 2.0 Web Client
# Redirect URI: https://yourdomain.com/api/auth/callback/google (or http://localhost:3000/... for dev)
# EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=YOUR_WEB_CLIENT_ID_HERE
# EXPO_PUBLIC_GOOGLE_CLIENT_SECRET_WEB=YOUR_WEB_CLIENT_SECRET_HERE
