# Google OAuth Configuration - TEMPLATE
# Copy this file to .env.local and fill in your actual credentials
# Get these from: https://console.cloud.google.com/

# Platform-specific credentials (recommended for better control)
# Web: needs both Client ID and Client Secret
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=YOUR_WEB_CLIENT_ID_HERE
EXPO_PUBLIC_GOOGLE_CLIENT_SECRET_WEB=YOUR_WEB_CLIENT_SECRET_HERE

# Android: only needs Client ID (no secret for mobile apps)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=YOUR_ANDROID_CLIENT_ID_HERE

# Optional: Fallback credentials (used if platform-specific ones are not set)
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GENERIC_CLIENT_ID_HERE
# EXPO_PUBLIC_GOOGLE_CLIENT_SECRET=YOUR_GENERIC_CLIENT_SECRET_HERE
